# Critter objective conditions

objective-condition-eat-food-title = Съесть { $count } { $count ->
    [one] кусок
    [few] куска
   *[other] кусков
} еды.
objective-condition-eat-food-description = Вы голодны! Найдите и съешьте { $count } { $count ->
    [one] кусок
    [few] куска
   *[other] кусков
} еды.

objective-condition-drink-liquid-title = Выпить { $count } единиц жидкости.
objective-condition-drink-liquid-description = Вы испытываете жажду! Найдите и выпейте { $count } единиц любой жидкости.

objective-condition-bite-title = Укусить { $count } { $count ->
