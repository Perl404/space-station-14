# Critter objective conditions

objective-condition-eat-food-title = Eat { $count } { $count ->
    [one] piece
   *[other] pieces
} of food.
objective-condition-eat-food-description = You're starving! Find and eat { $count } { $count ->
    [one] piece
   *[other] pieces
} of food.

objective-condition-drink-liquid-title = Drink { $count } { $count ->
    [one] unit
   *[other] units
} of liquid.
objective-condition-drink-liquid-description = You're parched! Find and drink { $count } { $count ->
    [one] unit
   *[other] units
} of any liquid.

objective-condition-melee-hit-title = Hit something { $count } { $count ->
    [one] time
   *[other] times
}.
objective-condition-melee-hit-description = Show your strength! Hit something { $count } { $count ->
    [one] time
   *[other] times
}.

objective-condition-walk-distance-title = Walk { $count } { $count ->
    [one] tile
   *[other] tiles
}.
objective-condition-walk-distance-description = Explore the station! Cover { $count } { $count ->
    [one] tile
   *[other] tiles
} on foot.

objective-condition-ingest-paper-title = Chew up { $count } { $count ->
    [one] sheet
   *[other] sheets
} of paper.
objective-condition-ingest-paper-description = Paper is delicious! Find and chew up { $count } { $count ->
    [one] sheet
   *[other] sheets
} of paper.
